# Inkwell — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Supabase project URL (find in: Supabase Dashboard → Settings → API)
VITE_SUPABASE_URL=https://atyopuiydzzurydeckdd.supabase.co

# Supabase anon/public key (safe to expose in client — RLS enforces security)
VITE_SUPABASE_ANON_KEY=sb_publishable_QA8j-W9gGiecqPdELifATA_OkVxcUYv

# ---- Edge Function Secrets (set in Supabase dashboard, NOT here) ----
# These are never in the client bundle. Set them with:
#   supabase secrets set ANTHROPIC_API_KEY=sk-ant-...
#
# ANTHROPIC_API_KEY=sk-ant-...   ← DO NOT put here

# Backend API URL (inkwell-backend server — for PDF export)
VITE_API_URL=http://localhost:3001
