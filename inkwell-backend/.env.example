# Inkwell Backend — copy this to .env and fill in your values

# Your Supabase project URL (same as VITE_SUPABASE_URL in the frontend)
SUPABASE_URL=https://your-project.supabase.co

# Service role key — from Supabase Dashboard → Project Settings → API → service_role
# KEEP THIS SECRET — never expose it in the frontend or commit it to git
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Allowed frontend origin for CORS
FRONTEND_URL=http://localhost:5173

# Port for the backend server
PORT=3001
